<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
  "http://www.freedesktop.org/standards/PolicyKit/1.0/policyconfig.dtd">
<policyconfig>

  <!--
    Ryzen Curve Optimizer - Polkit Action File
    ══════════════════════════════════════════════════════════════════
    A separate action id, fully independent of the m16R1-power-manager
    project's com.ryzenadj.gui.set-params action.

    IMPORTANT — the exec.path below must be the EXACT path of the
    installed helper, and the applet must invoke that path directly:

        pkexec /usr/lib/ryzen-curve-optimizer/ryzen_curve_optimizer_helper.py

    NOT `pkexec python3 .../helper.py`. polkit selects the action by
    matching the program pkexec is asked to run against exec.path, so
    passing the interpreter as the program makes this action unmatchable
    and silently falls back to polkit's generic exec action.

    The helper must also be root-owned and mode 0755 — pkexec refuses to
    run a program that is writable by group or other.

    install.sh handles all of this, and rewrites the path below if you
    install with a non-default PREFIX.
  -->

  <action id="com.ryzencurveoptimizer.set-curve">
    <description>Apply RyzenAdj Curve Optimizer values via the Ryzen Curve Optimizer applet</description>
    <description xml:lang="tr">Ryzen Curve Optimizer uygulaması üzerinden RyzenAdj Curve Optimizer değerlerini uygula</description>
    <message>Authentication is required to change the CPU Curve Optimizer voltage offsets</message>
    <message xml:lang="tr">CPU Curve Optimizer voltaj offsetlerini değiştirmek için kimlik doğrulama gerekiyor</message>

    <defaults>
      <allow_any>no</allow_any>
      <allow_inactive>no</allow_inactive>
      <allow_active>auth_admin_keep</allow_active>
    </defaults>

    <annotate key="org.freedesktop.policykit.exec.path">/usr/lib/ryzen-curve-optimizer/ryzen_curve_optimizer_helper.py</annotate>
    <annotate key="org.freedesktop.policykit.exec.allow_gui">true</annotate>
  </action>

</policyconfig>
